  "tour": [
    {
      "stop": 1,
      "title": "Servidor — Entry Point e Arquitetura",
      "file": "mazyui-server.mjs",
      "reason": "É o único processo que inicia tudo. 1107 linhas revelam o contrato inteiro servidor-cliente.",
      "keyConceptsToUnderstand": ["addRoute() — tabela de rotas", "handleRun() — spawna Claude + SSE", "safeResolve() — sandboxing de filesystem"],
      "nextFile": "brand.config.js",
      "nextReason": "Entender o modelo multi-instância e branding"
    },
    {
      "stop": 2,
      "title": "Configuração de Marca",
      "file": "brand.config.js",
      "reason": "Explica o modelo fork público — cada clone tem este arquivo diferente.",
      "keyConceptsToUnderstand": ["Fork MazyOS/sabec-os", "brand placeholders {{BRAND_*}} no HTML"],
      "nextFile": "mazyui-ui/index.js",
      "nextReason": "Ver como a SPA orquestra todos os módulos"
    },
    {
      "stop": 3,
      "title": "Entry Point da UI",
      "file": "mazyui-ui/index.js",
      "reason": "Único arquivo que wires tudo no browser — ordem de boot, painéis, injeção de deps.",
      "keyConceptsToUnderstand": ["window.Sabec = Sabec — contrato público", "setBoot({...}) — injeção para resolver ciclos"],
      "nextFile": "mazyui-ui/core/state.js",
      "nextReason": "Store compartilhado por todos os módulos"
    },
    {
      "stop": 4,
      "title": "Store Reativo",
      "file": "mazyui-ui/core/state.js",
      "reason": "Módulo mais importado (11 dependentes). Shape do state e distinção mutação direta vs update().",
      "keyConceptsToUnderstand": ["update(patch) = shallow merge + notify via microtask", "v1 lê state direto; v2 usa subscribe()"],
      "nextFile": "mazyui-ui/core/panels-registry.js",
      "nextReason": "Hub de extensibilidade e bridge para clientes"
    },
    {
      "stop": 5,
      "title": "Registry de Painéis + Sabec",
      "file": "mazyui-ui/core/panels-registry.js",
      "reason": "Hub de extensibilidade. Sabec global que clientes usam no local-ui.js. Lifecycle v1/v2.",
      "keyConceptsToUnderstand": ["mountPanel() — lifecycle completo", "v2 assina store automaticamente", "setRouterCallbacks() fecha ciclo sem import circular"],
      "nextFile": "mazyui-ui/panels/chat-stream.js",
      "nextReason": "Fluxo de ponta a ponta de uma mensagem ao Claude"
    },
    {
      "stop": 6,
      "title": "Streaming de Chat",
